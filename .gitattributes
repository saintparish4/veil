# Veil — line-ending policy.
#
# Shell scripts MUST be LF-only so `bash` (including WSL bash invoked from
# Windows) does not choke on carriage returns in constructs like
# `set -euo pipefail\r`. This applies on checkout regardless of the
# contributor's core.autocrlf setting.

*.sh         text eol=lf
*.bash       text eol=lf

# PowerShell is happy with either, but keep it consistent with the repo's
# default so diffs stay clean.
*.ps1        text eol=lf

# Binary-ish files git should never touch.
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
